{
  "manifest_version": 3,
  "name": "Gemini Summarizer",
  "version": "1.0",
  "description": "Summarize webpages with Gemini AI in simple English. Select specific parts or the entire page.",
  "action": {
    "default_popup": "popup/popup.html"
  },
  "permissions": [
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["config.js", "content/content.js"],
      "css": ["content/content.css"]
    }
  ]
}
